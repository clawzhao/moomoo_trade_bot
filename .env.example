MOOMOO_ACCOUNT_ID=your_account_id_here
MOOMOO_API_KEY=your_api_key_here
MOOMOO_API_SECRET=your_api_secret_here
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_MARKET=US
MOOMOO_ENV=SIMULATION

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
